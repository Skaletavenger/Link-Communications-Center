generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id            Int     @id @default(autoincrement())
  name          String
  model         String  @unique
  category      String
  price         Float
  stockQuantity Int
  image         String?
}
